OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_ROUTER_MODEL=google/gemini-2.0-flash-001
INJECTION_TEST_MODEL=anthropic/claude-sonnet-4

# Flask: leave FLASK_DEBUG unset for fast single-process server (no reloader). Set FLASK_DEBUG=1 only when editing code.
# FLASK_DEBUG=1
# PORT=8080
# FLASK_HOST=0.0.0.0

# Optional: run duckdb-local queries via MotherDuck (md:) with ATTACH + USE — same pattern as yelp-analytics.
# DUCKDB_LOCAL_USE_MOTHERDUCK=1
# MOTHERDUCK_TOKEN=

# Google MCP Toolbox: merge base + DuckDB overlay (requires toolbox build with duckdb-sql support).
# Paths are relative to the oracle-forge-data-agent repo root unless absolute.
# MCP_TOOLBOX_CONFIGS=agent/mcp/tools.yaml,agent/mcp/tools_duckdb.yaml

# Legacy Yelp-only URI for generated dab-src-duckdb-yelp-* (after DAB_TOOLBOX_DUCKDB_URI_YELP).
# DUCKDB_YELP_USER_PATH=/path/to/DataAgentBench/query_yelp/query_dataset/yelp_user.db
# MOTHERDUCK_TOKEN=... # required when any DuckDB URI uses md:…

# Optional: Yelp DuckDB for yelp-analytics (defaults to DataAgentBench query_yelp yelp_user.db)
# YELP_USER_DUCKDB_URI=md:my_database
# YELP_DUCKDB_REVIEW_FQN=main.review
# MOTHERDUCK_TOKEN=
# When MOTHERDUCK_TOKEN is set, the app ATTACHes the local yelp_user.db as yelp_dab and reads yelp_dab.review

# DataAgentBench checkout (eval harness: eval/config.yaml + python -m eval.harness)
# If unset, eval looks for a sibling ../DataAgentBench from the repo root.
# DAB_ROOT=/path/to/DataAgentBench

# MCP codegen: override DuckDB database URI in tools_dab_generated.yaml (MotherDuck md:… or any URI).
# Per-dataset wins: DAB_TOOLBOX_DUCKDB_URI_YELP, DAB_TOOLBOX_DUCKDB_URI_STOCKMARKET, etc. (slug uppercase, '-' -> '_')
# DAB_TOOLBOX_DUCKDB_URI_YELP=md:my_yelp_db
# DAB_TOOLBOX_DUCKDB_URI=md:shared_fallback
# Then: python3 -m agent.mcp.dab_toolbox_codegen --dab-root /path/to/DataAgentBench

# Append challenge_contract JSON lines from BenchmarkService trials
# BENCHMARK_WRITE_CONTRACT=1

# After each DAB run_agent trial, export contract to results/challenge_contracts.jsonl (requires ORACLE_FORGE_ROOT)
# ORACLE_FORGE_EXPORT_CONTRACT=1